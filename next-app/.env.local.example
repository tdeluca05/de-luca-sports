# ============================================================
# VARIABLES DE ENTORNO — DE LUCA SPORT
# Copia este archivo como .env.local y completá los valores.
# NUNCA subas .env.local a GitHub.
# ============================================================

# --- Supabase ---
# Encontrás estas claves en: supabase.com > tu proyecto > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# La service role key solo para operaciones de admin (no exponer en el cliente)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Mercado Pago ---
# Encontrás estas claves en: developers.mercadopago.com > Credenciales
# Usá las credenciales de PRUEBA (sandbox) para desarrollo
MP_ACCESS_TOKEN=APP_USR-0000000000000000-000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-000000000
NEXT_PUBLIC_MP_PUBLIC_KEY=APP_USR-00000000-0000-0000-0000-000000000000

# --- URL del sitio ---
# En desarrollo: http://localhost:3000
# En producción: tu URL de Vercel (ej: https://deluca-sport.vercel.app)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- WhatsApp (número sin + ni espacios) ---
NEXT_PUBLIC_WHATSAPP_NUMBER=5491165699188
